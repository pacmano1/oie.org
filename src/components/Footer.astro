---
import Icon from './Icon.astro';

const year = new Date().getFullYear();

const social = [
  { name: 'GitHub',   icon: 'github'   as const, href: 'https://github.com/OpenIntegrationEngine' },
  { name: 'LinkedIn', icon: 'linkedin' as const, href: 'https://www.linkedin.com/company/open-integration-engine' },
  { name: 'Discord',  icon: 'discord'  as const, href: 'https://discord.gg/azdehW2Zrx' },
  { name: 'Email',    icon: 'envelope' as const, href: 'mailto:info@openintegrationengine.org' },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <img src="/images/oie-logo.png" alt="" width="48" height="48" />
      <div>
        <div class="site-footer__brand-name">Open Integration Engine<sup>™</sup></div>
        <div class="site-footer__brand-tag">Free. Open Source. Trusted.</div>
      </div>
    </div>

    <nav class="site-footer__social" aria-label="Social links">
      {social.map((s) => (
        <a href={s.href} target={s.href.startsWith('mailto:') ? undefined : '_blank'} rel={s.href.startsWith('mailto:') ? undefined : 'noopener'} aria-label={s.name}>
          <Icon name={s.icon} />
        </a>
      ))}
    </nav>

    <div class="site-footer__meta">
      <p>© {year} The Open Integration Engine Project Authors. <a href="/privacy/">Privacy Policy</a></p>
      <p class="site-footer__disclaimer">
        Open Integration Engine™ is an independent project and is not affiliated with, endorsed by,
        or sponsored by NextGen Healthcare, Inc. Mirth® and Mirth® Connect are registered trademarks
        of NextGen Healthcare, Inc.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-footer-bg);
    color: var(--color-footer-text);
    padding: 3rem 0 2rem;
    margin-top: 4rem;
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "brand social"
      "meta meta";
    gap: 2rem;
    align-items: center;
  }

  .site-footer__brand {
    grid-area: brand;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .site-footer__brand img { border-radius: 6px; }

  .site-footer__brand-name {
    font-weight: 700;
    color: var(--color-footer-heading);
    font-size: 1.1rem;
  }
  .site-footer__brand-tag { font-size: 0.85rem; }

  .site-footer__social {
    grid-area: social;
    display: flex;
    gap: 1rem;
  }

  .site-footer__social a {
    color: var(--color-footer-link);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .site-footer__social a:hover {
    color: var(--color-footer-link-hover);
    background: rgba(8, 145, 178, 0.08);
  }

  .site-footer__meta {
    grid-area: meta;
    border-top: 1px solid var(--color-divider);
    padding-top: 1.5rem;
    font-size: 0.875rem;
  }
  .site-footer__meta p { margin-bottom: 0.5rem; }
  .site-footer__meta a { color: var(--color-footer-link); }
  .site-footer__meta a:hover { color: var(--color-footer-link-hover); }

  .site-footer__disclaimer {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 700px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      grid-template-areas:
        "brand"
        "social"
        "meta";
    }
  }
</style>
