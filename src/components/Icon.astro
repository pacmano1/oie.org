const { name, size = 22, class: className = '' } = Astro.props;
const icon = ICONS[name];
const isFill = icon.kind === 'fill';
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isFill ? 'currentColor' : 'none'}
  stroke={isFill ? undefined : 'currentColor'}
  stroke-width={isFill ? undefined : 2}
  stroke-linecap={isFill ? undefined : 'round'}
  stroke-linejoin={isFill ? undefined : 'round'}
  aria-hidden="true"
  class={className}
  set:html={icon.body}
/>
