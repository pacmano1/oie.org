---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const posts = (await getCollection('news')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="News - Open Integration Engine" description="Announcements and release news from the Open Integration Engine project.">
  <article class="page">
    <PageHero title="News" lead="Release announcements and project updates." />

    <section class="news">
      <div class="container">
        <ul class="news-grid">
          {posts.map((post) => (
            <li class="card card--hover card--lift">
              <a class="news-card__link" href={`/news/${post.id}/`}>
                <time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
                <h2>{post.data.title}</h2>
                {post.data.excerpt && <p>{post.data.excerpt}</p>}
                <span class="news-card__more">Read article →</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .page { padding: 3rem 0 2rem; }
  .news { padding: 1rem 0 4rem; }

  .news-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .news-card__link {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: var(--card-padding-sm);
    color: inherit;
    height: 100%;
  }
  .news-card__link:hover { color: inherit; }

  .news-grid time {
    font-size: 0.8rem;
    color: var(--color-base);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .news-grid h2 {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--color-headings);
  }

  .news-grid p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-base);
    flex: 1;
  }

  .news-card__more {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.5rem;
  }

  @media (max-width: 900px) {
    .news-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .news-grid { grid-template-columns: 1fr; }
  }
</style>
