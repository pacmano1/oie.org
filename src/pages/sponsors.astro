---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { sponsors } from '../data/sponsors';
---

<BaseLayout title="Sponsors - Open Integration Engine" description="Companies that support the Open Integration Engine project.">
  <article class="container page">
    <PageHero title="Sponsors and Acknowledgments" />

    <p class="page-lead">
      Many companies and individuals have donated their time, skills, and funds to ensure
      the ongoing development and delivery of the Open Integration Engine. This project is
      made possible by the generous support of those listed below. If you are interested
      in sponsorship, please <a href="/contact/">contact us</a>.
    </p>

    <h2>Companies</h2>
    <ul class="sponsor-grid">
      {sponsors.map((s) => (
        <li class="card card--hover">
          <a href={s.url} target="_blank" rel="noopener" aria-label={s.name} title={s.name}>
            <img src={s.logo} alt={s.name} loading="lazy" />
          </a>
        </li>
      ))}
    </ul>
  </article>
</BaseLayout>

<style>
  .page { padding: 3rem 0 4rem; }
  .page-lead { text-align: center; max-width: 720px; margin: -1.5rem auto 3rem; }
  .page > h2 { text-align: center; margin-bottom: 1.5rem; }

  .sponsor-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  .sponsor-grid li {
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 3 / 2;
  }
  .sponsor-grid a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }
  .sponsor-grid img {
    max-width: 100%;
    max-height: 80px;
    object-fit: contain;
  }
</style>
