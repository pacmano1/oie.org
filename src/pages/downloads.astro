---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const releaseCandidate = {
  version: '4.6.0-rc1',
  url: 'https://github.com/OpenIntegrationEngine/engine/releases/tag/v4.6.0-rc1',
};

const currentRelease = {
  version: '4.5.2',
  url: 'https://github.com/OpenIntegrationEngine/engine/releases/tag/v4.5.2',
};
---

<BaseLayout title="Downloads - Open Integration Engine" description="Download the latest Open Integration Engine release.">
  <article class="container-narrow page">
    <PageHero
      title="Downloads"
      lead="Open Integration Engine is stable and ready for production use. The 4.5.2 release is recommended for most users. A 4.6.0 release candidate is also available for community testing."
    />

    <section>
      <p>Installers are available including:</p>
      <ul>
        <li>A full version <strong>with a bundled JRE</strong> for fast, hassle-free setup</li>
        <li>A lightweight version <strong>without a JRE</strong> for custom environments</li>
      </ul>
    </section>

    <section class="card card--padded download">
      <p class="release-label">Release candidate</p>
      <h2>Open Integration Engine {releaseCandidate.version}</h2>
      <p class="release-note">Available for testing and feedback. Not recommended for production use.</p>
      <p>
        <a class="button" href={releaseCandidate.url} target="_blank" rel="noopener">
          Download v{releaseCandidate.version} from GitHub
        </a>
      </p>
      <p class="meta">
        <a href="/news/oie-4-6-0-rc1/">Read what's new in 4.6.0-rc1</a>
      </p>
    </section>

    <section class="card card--padded download">
      <p class="release-label">Current stable release</p>
      <h2>Open Integration Engine {currentRelease.version}</h2>
      <p class="release-note">Recommended for production use.</p>
      <p>
        <a class="button" href={currentRelease.url} target="_blank" rel="noopener">
          Download v{currentRelease.version} from GitHub
        </a>
      </p>
      <p class="meta">
        All releases: <a href="https://github.com/OpenIntegrationEngine/engine/releases" target="_blank" rel="noopener">github.com/OpenIntegrationEngine/engine/releases</a>
      </p>
    </section>

    <p class="license-note">
      Released under the <a href="https://www.mozilla.org/en-US/MPL/2.0/" target="_blank" rel="noopener">Mozilla Public License 2.0</a>.
    </p>
  </article>
</BaseLayout>

<style>
  .page { padding: 3rem 0 4rem; }
  .page :global(.lead) { font-size: 1.15rem; }
  section { margin-bottom: 1.5rem; }
  .download { text-align: center; }
  .download h2 { margin: 0.25rem 0 0.5rem; }
  .download .release-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-headings);
    margin: 0;
  }
  .download .release-note {
    font-size: 0.95rem;
    color: var(--color-base);
    margin: 0 0 1rem;
  }
  .download .meta { font-size: 0.9rem; color: var(--color-base); margin-bottom: 0; }
  .license-note { text-align: center; font-size: 0.9rem; color: var(--color-base); margin-top: 1.5rem; }
</style>
